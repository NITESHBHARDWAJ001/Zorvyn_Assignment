NODE_ENV=development
PORT=4000
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=finance
DATABASE_URL="postgresql://postgres:postgres@db:5432/finance?schema=public"
JWT_SECRET="replace-with-a-strong-secret"
JWT_EXPIRES_IN="1h"
CORS_ORIGIN="http://localhost:3000"
SWAGGER_SERVER_URLS="http://localhost:4000,https://api.example.com"
PRISMA_DB_SYNC_STRATEGY="migrate-then-push"
BOOTSTRAP_ADMIN="false"
BOOTSTRAP_ADMIN_NAME="System Admin"
BOOTSTRAP_ADMIN_EMAIL="admin@example.com"
BOOTSTRAP_ADMIN_PASSWORD="ChangeMe123!"
